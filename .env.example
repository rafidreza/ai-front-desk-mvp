INTERNAL_CONSOLE_PASSWORD=change-this-before-sharing
INTERNAL_CONSOLE_SESSION_SECRET=change-this-long-random-secret
CLIENT_AUTH_CODE_SECRET=change-this-long-random-client-auth-secret
DEV_RETURN_AUTH_CODE=false
CLIENT_SESSION_SECRET=change-this-long-random-client-session-secret
