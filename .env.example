PORT=4000
NODE_ENV=development
WEB_APP_URL=http://localhost:3002
API_BASE_URL=http://localhost:4000
INTERNAL_API_TOKEN=change-this-long-random-api-token
DATABASE_URL=postgresql://user:password@host/database?sslmode=verify-full

MESSENGER_VERIFY_TOKEN=replace-with-meta-webhook-token
ENABLE_MESSENGER=false
MESSENGER_APP_SECRET=
MESSENGER_PAGE_ACCESS_TOKEN=

ENABLE_P1_WHATSAPP_PINGS=true
WHATSAPP_GRAPH_VERSION=v20.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

EMAIL_FROM_ADDRESS=AI Front Desk <support@example.com>
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound

ANTHROPIC_API_KEY=
